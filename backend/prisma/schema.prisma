// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Brand {
  id        String    @id @default(cuid())
  name      String
  products  Product[]

  @@map("brand")
}

model Color {
  id        String    @id @default(cuid())
  name      String
  products  Product[]

  @@map("color")
}

model ProductType {
  id        String    @id @default(cuid())
  name      String
  products  Product[]

  @@map("product_type")
}

model Size {
  id        String    @id @default(cuid())
  name      String
  products  Product[]

  @@map("size")
}

model Product {
  id                      String                   @id @default(cuid())
  name                    String
  price                   Float
  quantity                Int
  colorId                 String
  color                   Color                    @relation(fields: [colorId], references: [id])
  typeId                  String
  type                    ProductType              @relation(fields: [typeId], references: [id])
  brandId                 String
  brand                   Brand                    @relation(fields: [brandId], references: [id])
  sizeId                  String
  size                    Size                     @relation(fields: [sizeId], references: [id])
  customerOrderDetails    CustomerOrderDetail[]
  purchaseOrderDetails    PurchaseOrderDetail[]
  goodsReceiptDetails     GoodsReceiptDetail[]

  @@map("product")
}

model Role {
  id    String  @id @default(cuid())
  name  String
  staff Staff[]

  @@map("role")
}

model Customer {
  id                String           @id @default(cuid())
  fullName          String
  phoneNumber       String
  customerOrders    CustomerOrder[]

  @@map("customer")
}

model Staff {
  id              String            @id @default(cuid())
  staffID         String            @unique
  fullName        String
  age             Int
  gender          String
  address         String
  phoneNumber     String
  roleId          String
  role            Role              @relation(fields: [roleId], references: [id])
  isWorking       Boolean           @default(true)
  customerOrders  CustomerOrder[]
  purchaseOrders  PurchaseOrder[]
  goodsReceipts   GoodsReceipt[]

  @@map("staff")
}

model Provider {
  id              String            @id @default(cuid())
  name            String
  address         String
  phoneNumber     String
  purchaseOrders  PurchaseOrder[]
  goodsReceipts   GoodsReceipt[]

  @@map("provider")
}

model CustomerOrder {
  id                    String                @id @default(cuid())
  customerId            String
  customer              Customer              @relation(fields: [customerId], references: [id])
  totalPrice            Float
  staffId               String
  staff                 Staff                 @relation(fields: [staffId], references: [id])
  cancelReason          String?
  customerOrderDetails  CustomerOrderDetail[]

  @@map("customer_order")
}

model CustomerOrderDetail {
  id              String         @id @default(cuid())
  customerOrderId String
  customerOrder   CustomerOrder  @relation(fields: [customerOrderId], references: [id])
  productId       String
  product         Product        @relation(fields: [productId], references: [id])
  quantity        Int
  price           Float

  @@map("customer_order_detail")
}

model PurchaseOrder {
  id                      String                  @id @default(cuid())
  createdDate             DateTime                @default(now())
  managerId               String
  manager                 Staff                   @relation(fields: [managerId], references: [id])
  providerId              String
  provider                Provider                @relation(fields: [providerId], references: [id])
  purchaseOrderDetails    PurchaseOrderDetail[]

  @@map("purchase_order")
}

model PurchaseOrderDetail {
  id              String         @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id])
  productId       String
  product         Product        @relation(fields: [productId], references: [id])
  quantity        Int

  @@map("purchase_order_detail")
}

model GoodsReceipt {
  id                  String                @id @default(cuid())
  createdDate         DateTime              @default(now())
  totalPrice          Float
  staffId             String
  staff               Staff                 @relation(fields: [staffId], references: [id])
  providerId          String
  provider            Provider              @relation(fields: [providerId], references: [id])
  goodsReceiptDetails GoodsReceiptDetail[]

  @@map("goods_receipt")
}

model GoodsReceiptDetail {
  id              String       @id @default(cuid())
  goodsReceiptId  String
  goodsReceipt    GoodsReceipt @relation(fields: [goodsReceiptId], references: [id])
  productId       String
  product         Product      @relation(fields: [productId], references: [id])
  quantity        Int
  price           Float

  @@map("goods_receipt_detail")
}
